# =============================================================================
# Nexus Agents — Variables de Entorno
# =============================================================================
# Copia este archivo a .env y completa los valores:
#   cp .env.example .env
# =============================================================================

# Timezone
TZ=America/Monterrey

# ---------------------------------------------------------------------------
# Workspace compartido
# Ruta en el HOST donde está el código (ERP-DOCKER-STACK)
# ---------------------------------------------------------------------------
WORKSPACE_PATH=/config/ERP-DOCKER-STACK

# ---------------------------------------------------------------------------
# Directorio con los archivos JSON de credenciales de túneles Cloudflare
# ---------------------------------------------------------------------------
TUNNELS_DIR=./tunnels

# ---------------------------------------------------------------------------
# API Keys de los agentes
# ---------------------------------------------------------------------------
DEEPSEEK_API_KEY=sk-your-deepseek-key
ANTIGRAVITY_API_KEY=your-antigravity-key
CODEX_API_KEY=your-codex-key

# ---------------------------------------------------------------------------
# Credenciales de túneles Cloudflare (opcional — montar como archivo)
# Si no montas los archivos JSON en ./tunnels/, define las credenciales aquí.
# ATENCIÓN: Las credenciales reales son SENSIBLES. No las subas a GitHub.
# ---------------------------------------------------------------------------

# Antigravity tunnel (bfdfe5dd...)
# ANTIGRAVITY_TUNNEL_CREDS={"AccountTag":"c00f175ffd87599332aa9695fe52717f","TunnelID":"bfdfe5dd...","TunnelSecret":"..."}

# Codex tunnel (7b806aad...)
# CODEX_TUNNEL_CREDS={"AccountTag":"c00f175ffd87599332aa9695fe52717f","TunnelID":"7b806aad...","TunnelSecret":"..."}
